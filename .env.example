# Stripe test keys (https://dashboard.stripe.com/test/apikeys)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_TEST_SECRET_KEY=sk_test_your_secret_key_here

# Optional: Stripe webhook signing secret for local testing
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Financing provider (generic scaffold — add your lender API details)
FINANCING_PROVIDER_NAME=Solar Financing Partner
FINANCING_API_URL=
FINANCING_API_KEY=
FINANCING_MERCHANT_ID=

# WordPress admin (used on first install only)
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@sunrooflighting.test

# Quote notification email (defaults to WP admin email)
QUOTE_NOTIFICATION_EMAIL=
